{
  "name": "dispatch-system",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "node server/dist/index.js",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:push": "pnpm -F @dispatch/server run db:push",
    "db:studio": "pnpm -F @dispatch/server run db:studio"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "dotenv": "^16.6.1",
    "drizzle-orm": "0.36.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.0",
    "drizzle-kit": "0.28.0",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  }
}