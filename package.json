{
  "name": "dispatch-system",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "node server/dist/server/index.js",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "seed:demo": "pnpm --filter @dispatch/server exec tsx ../scripts/seed-demo.ts"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "dotenv": "^16.6.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  }
}
