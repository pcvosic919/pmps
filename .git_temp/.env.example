# PMP System - Environment Variables Example

# --- Database ---
# Local SQLite example: file:./sqlite.db
# Azure SQL / PostgreSQL / Turso example: libsql://your-db-name.turso.io
DATABASE_URL=file:./sqlite.db

# --- Authentication ---
JWT_SECRET=replace_with_a_long_random_string_in_production

# --- AI Integration ---
# Google Gemini API Key
GOOGLE_AI_KEY=your_google_gemini_api_key_here

# --- Microsoft Entra ID (SSO) ---
ENTRA_TENANT_ID=your_tenant_id
ENTRA_CLIENT_ID=your_client_id
ENTRA_CLIENT_SECRET=your_client_secret

# --- Server Config ---
PORT=5000
NODE_ENV=development
