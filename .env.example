# -----------------------------------------------------------------------------
# PMP System - 後端環境變數範例檔 (.env.example)
# 使用方式：請複製此檔案並重新命名為 `.env`，再依據您的環境填入對應數值。
# -----------------------------------------------------------------------------

# [伺服器設定]
PORT=5000

# [資料庫連線]
# 本地測試範例：mongodb://localhost:27017/pmp_system
# Azure Cosmos DB 範例
MONGODB_URI=mongodb://<username>:<password>@<host>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<app-name>@

# [認證安全]
# 請替換為高強度的隨機字串
JWT_SECRET=pmp-secret-key-change-this-in-production

# [AI 報表整合]
# 前往 Google AI Studio 申請 API Key 以便啟用「AI 報表故事」生成真實語意分析
GEMINI_API_KEY=
